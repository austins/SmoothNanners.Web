{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "schedule:daily",
        ":enableVulnerabilityAlerts",
        ":rebaseStalePrs",
        ":automergePr",
        ":automergeRequireAllStatusChecks",
        ":automergeMinor",
        "npm:unpublishSafe"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "datasourceTemplate": "npm",
            "versioningTemplate": "npm",
            "fileMatch": [
                "(^|/)libman.json$"
            ],
            "matchStrings": [
                "\"library\": ?\"(?<depName>@?[^\"]+?)@(?<currentValue>.*?)\""
            ]
        }
    ]
}
