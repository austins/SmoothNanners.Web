<PortalLink Variant="Variant.Slate" Icon="BootstrapIcon.Globe" Href="@Href">
    @ChildContent
</PortalLink>

@code {
    [Parameter]
    [EditorRequired]
    public required string Href { get; init; }

    [Parameter]
    [EditorRequired]
    public required RenderFragment ChildContent { get; init; }
}
