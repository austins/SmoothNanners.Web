@page
@model Index

<div id="bio">
    <img
        src="~/images/avatar.webp"
        asp-append-version="true"
        width="200"
        height="200"
        alt="@AppConstants.SiteName"
        decoding="async"
        loading="eager"
    />

    <div>
        <p>Howdy! My name is Austin.</p>
        <p>I'm a gamer, musician, software engineer, and photographer.</p>
        <p>You can find links to my content and websites below!</p>
    </div>
</div>

<div id="portal">
    <div id="portal-left">
        <portal-card variant="Indigo" heading-icon="Ionicon.MusicalNotesOutline" heading-text="Music">
            <youtube-link channel-id="UCPjcGsO8o_FKPGHLQ5d1hbg"/>

            <youtube-embeds
                video-ids="@(["XjIJoM1AZyQ", "aPtQZNellaI"])"/>
        </portal-card>
    </div>

    <div id="portal-right">
        <portal-card variant="Pink" heading-icon="Ionicon.GameControllerOutline" heading-text="Gaming">
            <youtube-link channel-id="UCQB1XVER5WPtxRESxHMG1Qw"/>

            <portal-link
                variant="Purple"
                icon="Ionicon.LogoTwitch"
                href="https://www.twitch.tv/smoothnanners"
            >
                Twitch
            </portal-link>

            <portal-link
                variant="Indigo"
                icon="Ionicon.LogoDiscord"
                href="https://discord.gg/P7rhAhA"
            >
                Discord
            </portal-link>

            <website-link href="https://gamebyline.com/">
                Game Byline
            </website-link>
        </portal-card>

        <portal-card variant="Cyan" heading-icon="Ionicon.TerminalOutline" heading-text="Programming">
            <youtube-link channel-id="UCJjowuNoLywGC7ujP74zFJg"/>

            <portal-link
                variant="Slate"
                icon="Ionicon.LogoGithub"
                href="https://github.com/austins"
            >
                GitHub
            </portal-link>

            <website-link href="https://austinsdev.com/">
                Austin's Dev
            </website-link>
        </portal-card>

        <portal-card variant="Blue" heading-icon="Ionicon.PersonCircleOutline" heading-text="Socials">
            <portal-link
                variant="Fuchsia"
                icon="Ionicon.LogoInstagram"
                href="https://www.instagram.com/smoothnanners">
                Instagram
            </portal-link>

            <portal-link
                variant="Sky"
                icon="Ionicon.PaperPlane"
                href="https://t.me/smoothnanners">
                Telegram
            </portal-link>

            <portal-link
                variant="Black"
                icon="Ionicon.LogoX"
                href="https://x.com/smoothnanners">
                Twitter
            </portal-link>

            <portal-link
                variant="Slate"
                icon="Ionicon.Gift"
                href="https://streamlabs.com/smoothnanners/tip">
                Tip
            </portal-link>

            <portal-link
                variant="Slate"
                icon="Ionicon.Mail"
                href="mailto:austin@austinsdev.com">
                Email
            </portal-link>
        </portal-card>
    </div>
</div>
