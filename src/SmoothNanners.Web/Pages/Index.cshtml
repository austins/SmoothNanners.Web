@page
@model IndexModel

<div class="d-sm-flex mb-3">
    <div class="mb-2 mb-sm-0 flex-sm-shrink-0 me-sm-3">
        <img src="~/assets/images/avatar.jpg" asp-append-version="true"
             alt="@AppConstants.SiteName" width="171.35" height="171.35" class="rounded"/>
    </div>

    <div class="flex-sm-grow-1 fs-5">
        <p>Howdy! My name is Austin.</p>

        <p>I'm a gamer, musician, software engineer, and photographer.</p>

        <p>You can find links to my content and websites below!</p>
    </div>
</div>

<div class="row gx-3">
    <div class="col-12 mb-3 col-sm-6 mb-sm-0">
        <portal-section heading-text="Music" icon="MusicNoteBeamed" variant="Primary">
            <portal-link url="https://www.youtube.com/channel/UCPjcGsO8o_FKPGHLQ5d1hbg" text="YouTube"
                         icon="Youtube"
                         variant="Danger"/>

            @{ IList<string> videoIds = ["lnWtTXtXc0A", "XjIJoM1AZyQ"]; }
            <youtube-embeds video-ids="videoIds"/>
        </portal-section>
    </div>

    <div class="col-12 col-sm-6">
        <div class="vstack gap-3">
            <portal-section heading-text="Gaming" icon="Controller" variant="Danger">
                <portal-link url="https://www.youtube.com/channel/UCQB1XVER5WPtxRESxHMG1Qw" text="YouTube"
                             icon="Youtube"
                             variant="Danger"/>

                <portal-link url="https://www.twitch.tv/smoothnanners" text="Twitch" icon="Twitch" variant="Primary"/>

                <portal-link url="https://discord.gg/P7rhAhA" text="Discord" icon="Discord" variant="Dark"/>

                <portal-link url="https://gamebyline.com/" text="Game Byline" icon="Globe" variant="Dark"/>
            </portal-section>

            <portal-section heading-text="Programming" icon="CodeSlash" variant="Light">
                <portal-link url="https://www.youtube.com/channel/UCJjowuNoLywGC7ujP74zFJg" text="YouTube"
                             icon="Youtube" variant="Danger"/>

                <portal-link url="https://github.com/austins" text="GitHub" icon="Github" variant="Dark"/>

                <portal-link url="https://austinsdev.com/" text="Austin's Dev" icon="Globe" variant="Dark"/>
            </portal-section>

            <portal-section heading-text="Social" icon="PersonCircle" variant="Primary">
                <portal-link url="https://twitter.com/smoothnanners" text="Twitter" icon="TwitterX" variant="Info"/>

                <portal-link url="https://www.instagram.com/smoothnanners" text="Instagram" icon="Instagram"
                             variant="Primary"/>

                <portal-link url="https://streamlabs.com/smoothnanners/tip" text="Tip" icon="CashCoin" variant="Dark"/>

                <portal-link url="mailto:austin@austinsdev.com" text="Email" icon="At" variant="Dark"/>
            </portal-section>
        </div>
    </div>
</div>
