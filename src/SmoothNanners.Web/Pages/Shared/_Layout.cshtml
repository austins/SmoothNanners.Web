@using System.Reflection
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData.TryGetTitle(out var title) ? $"{title} | {AppConstants.SiteName}" : AppConstants.SiteName)</title>
    <link rel="stylesheet" href="~/assets/vendors/bootswatch/dist/vapor/bootstrap.min.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/@(Assembly.GetExecutingAssembly().GetName().Name).styles.css"
          asp-append-version="true"/>
    <script src="~/assets/vendors/alpinejs/dist/cdn.min.js" asp-append-version="true" defer></script>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true"/>
    <meta name="description" content="@AppConstants.SiteDescription"/>
    @await RenderSectionAsync("Head", false)
</head>
<body>
<div id="body-inner" class="d-flex min-vh-100 align-items-center text-white">
    <div class="container py-3">
        <header class="pb-2">
            <h1 class="fw-bold">@AppConstants.SiteName</h1>
        </header>

        <main>@RenderBody()</main>
    </div>
</div>
</body>
</html>
