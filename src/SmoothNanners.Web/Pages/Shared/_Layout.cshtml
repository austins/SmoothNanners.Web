@{
    Layout = "_LayoutBase";
}

@RenderBody()

@section Head {
    @await RenderSectionAsync("Head", false)

    @foreach (var (src, defer) in ViewData.GetScripts())
    {
        var appendVersion = src.StartsWith("~/", StringComparison.Ordinal) || src.StartsWith('/');
        if (defer)
        {
            <script defer src="@src" asp-append-version="appendVersion"></script>
        }
        else
        {
            <script src="@src" asp-append-version="appendVersion"></script>
        }
    }
}
