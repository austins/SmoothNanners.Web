@{
    Layout = "_LayoutBase";
}

@RenderBody()

@section Head {
    @await RenderSectionAsync("Head", false)

    @foreach (var (path, isLocalScript) in ViewContext.GetScripts())
    {
        if (isLocalScript)
        {
            <script defer src="@path" asp-append-version="true"></script>
        }
        else
        {
            <script defer src="@path"></script>
        }
    }
}
