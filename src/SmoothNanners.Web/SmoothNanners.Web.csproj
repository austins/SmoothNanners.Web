<Project Sdk="Microsoft.NET.Sdk.Web">
    <ItemGroup>
        <PackageReference Include="AspNetStatic" Version="0.21.0"/>
        <PackageReference Include="BootstrapIcons.AspNetCore" Version="1.11.0"/>
        <PackageReference Include="SafeRouting" Version="1.5.0"/>
    </ItemGroup>

    <ItemGroup>
        <Watch Include="tailwind.config.js"/>
        <Content Update="appsettings.Development.json;libman.json" CopyToPublishDirectory="Never"/>
    </ItemGroup>

    <Target Name="RestoreTools" BeforeTargets="Build">
        <Exec Command="dotnet tool restore"/>
    </Target>

    <Target Name="RestoreLibman" AfterTargets="RestoreTools" Condition="!Exists('wwwroot\assets\vendors')">
        <Exec Command="dotnet tool run libman restore"/>
    </Target>

    <Target Name="BuildTailwindCss" AfterTargets="RestoreLibman">
        <Exec Command="dotnet tool run tailwindcss -i tailwind.css -o ./wwwroot/assets/main.css -m"/>
    </Target>
</Project>
