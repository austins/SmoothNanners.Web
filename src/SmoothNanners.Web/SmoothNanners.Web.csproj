<Project Sdk="Microsoft.NET.Sdk.Web">
    <ItemGroup>
        <PackageReference Include="AspNetStatic" Version="0.21.0"/>
        <PackageReference Include="BootstrapIcons.AspNetCore" Version="1.11.0"/>
        <PackageReference Include="SafeRouting" Version="1.5.0"/>
    </ItemGroup>

    <ItemGroup>
        <Watch Include="*.config.js;Assets\**\*" Exclude="wwwroot\assets\**\*"/>
        <Content Update="appsettings.Development.json;package.json" CopyToPublishDirectory="Never"/>
    </ItemGroup>

    <Target Name="EnsurePnpmEnv" BeforeTargets="Build" Condition="!Exists('node_modules')">
        <Exec Command="pnpm -v" ContinueOnError="true">
            <Output TaskParameter="ExitCode" PropertyName="ErrorCode"/>
        </Exec>
        <Error Condition="'$(ErrorCode)' != '0'" Text="Node.js and pnpm is required to build and run this project. To continue, please install Node.js and pnpm, then restart your command prompt or IDE."/>
        <Message Importance="high" Text="Restoring dependencies using 'pnpm'..."/>
        <Exec Command="pnpm i --frozen-lockfile"/>
    </Target>

    <Target Name="BuildAssets" AfterTargets="Build">
        <Exec Command="pnpm run build"/>
    </Target>
</Project>
