<Project Sdk="Microsoft.NET.Sdk.Web">
    <PropertyGroup>
        <DefaultItemExcludes>$(DefaultItemExcludes);node_modules\**;*.tsbuildinfo</DefaultItemExcludes>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="AspNetStatic" Version="0.26.6"/>
        <PackageReference Include="BootstrapIcons.AspNetCore" Version="1.11.0"/>
        <PackageReference Include="SafeRouting" Version="1.5.0"/>
        <PackageReference Include="TechGems.RazorComponentTagHelpers" Version="1.1.0"/>
    </ItemGroup>

    <ItemGroup>
        <Using Include="Microsoft.AspNetCore.Mvc"/>
        <Using Include="Microsoft.AspNetCore.Mvc.RazorPages"/>
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="$(AssemblyName).Tests.Integration"/>
    </ItemGroup>

    <ItemGroup>
        <Content Update="appsettings.Development.json;package.json;tsconfig.json" CopyToPublishDirectory="Never"/>
    </ItemGroup>

    <Target Name="EnsureJsEnv" BeforeTargets="Build" Condition="!Exists('node_modules')">
        <Exec Command="node --version" ContinueOnError="true">
            <Output TaskParameter="ExitCode" PropertyName="ErrorCode"/>
        </Exec>
        <Error Condition="'$(ErrorCode)' != '0'" Text="Node.js is required to build and run this project."/>
        <Message Importance="high" Text="Restoring dependencies using 'pnpm'..."/>
        <Exec Command="pnpm install --frozen-lockfile"/>
    </Target>

    <Target Name="BuildAssets" AfterTargets="BeforeBuild">
        <Exec Command="pnpm run build"/>
    </Target>

    <Target Name="CleanAssets" AfterTargets="Clean">
        <RemoveDir Directories="wwwroot\assets"/>
    </Target>
</Project>
