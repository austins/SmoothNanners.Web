<Project Sdk="Microsoft.NET.Sdk.Web">
    <ItemGroup>
        <PackageReference Include="AspNetStatic" Version="0.21.0"/>
        <PackageReference Include="BootstrapIcons.AspNetCore" Version="1.11.0"/>
        <PackageReference Include="SafeRouting" Version="1.5.0"/>
    </ItemGroup>

    <ItemGroup>
        <Watch Include="*.config.js;Assets\**\*" Exclude="wwwroot\assets\**\*"/>
        <Content Update="appsettings.Development.json;package.json" CopyToPublishDirectory="Never"/>
    </ItemGroup>

    <Target Name="EnsureBunEnv" BeforeTargets="Build" Condition="!Exists('node_modules')">
        <Exec Command="bun -v" ContinueOnError="true">
            <Output TaskParameter="ExitCode" PropertyName="ErrorCode"/>
        </Exec>
        <Error Condition="'$(ErrorCode)' != '0'" Text="Bun is required to build and run this project. To continue, please install it as administrator from https://bun.sh/, and then restart your command prompt or IDE."/>
        <Message Importance="high" Text="Restoring dependencies using 'bun'..."/>
        <Exec Command="bun install"/>
    </Target>

    <Target Name="BuildAssets" AfterTargets="Build">
        <Exec Command="bun run build"/>
    </Target>
</Project>
