{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "bun run build:js && bun run build:css",
        "build:js": "tsc --incremental --noEmit && bun ./build-assets.ts",
        "build:css": "bun run --bun tailwindcss -i ./Assets/main.css -o ./wwwroot/assets/main.css -m"
    },
    "peerDependencies": {
        "typescript": "^5.5.2"
    },
    "devDependencies": {
        "@types/alpinejs": "^3.13.10",
        "@types/bun": "^1.1.5",
        "alpinejs": "^3.14.1",
        "tailwindcss": "^3.4.4"
    }
}
